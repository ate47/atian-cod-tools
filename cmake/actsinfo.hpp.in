#pragma once
namespace core::actsinfo {
    // Do not write in this file, it is updated by cmake

    constexpr unsigned int DEV_VERSION_ID = 0xFFFFFFFF;
    constexpr unsigned int BUILD_VERSION_ID = 0x${VERSION_ID};

#ifdef CI_BUILD

    // Version used for the release

#ifdef GPL_BUILD

    constexpr const char* VERSION = "${VERSION}-gpl";
    constexpr const wchar_t* VERSIONW = L"${VERSION}-gpl";

#else

    constexpr const char* VERSION = "${VERSION}";
    constexpr const wchar_t* VERSIONW = L"${VERSION}";

#endif // GPL_BUILD

    constexpr unsigned int VERSION_ID = BUILD_VERSION_ID;

#else



#ifdef PRERELEASE_BUILD

    // prerelease

#ifdef GPL_BUILD

    constexpr const char* VERSION = "${VERSION}-gpl-pre";
    constexpr const wchar_t* VERSIONW = L"${VERSION}-gpl-pre";

#else

    constexpr const char* VERSION = "${VERSION}-pre";
    constexpr const wchar_t* VERSIONW = L"${VERSION}-pre";

#endif // GPL_BUILD

#else


#ifdef GPL_BUILD

    constexpr const char* VERSION = "dev-${VERSION}-gpl";
    constexpr const wchar_t* VERSIONW = L"dev-${VERSION}-gpl";

#else

    constexpr const char* VERSION = "dev-${VERSION}";
    constexpr const wchar_t* VERSIONW = L"dev-${VERSION}";

#endif // GPL_BUILD


#endif // PRERELEASE_BUILD

    // Disable updater

    constexpr unsigned int VERSION_ID = DEV_VERSION_ID;


#endif // CI_BUILD

}